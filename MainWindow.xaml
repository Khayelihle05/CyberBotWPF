<Window x:Class="CyberBotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="720"
        Width="1000"
        Background="#101820">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <Border Grid.Row="0"
                Background="#1B263B"
                Margin="10"
                CornerRadius="15">

            <StackPanel VerticalAlignment="Center">

                <TextBlock
                    Text="🛡 CYBERSECURITY AWARENESS BOT"
                    Foreground="Cyan"
                    FontSize="30"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"/>

                <TextBlock
                    Text="Stay Safe Online • Protect Your Data"
                    Foreground="White"
                    FontSize="16"
                    HorizontalAlignment="Center"/>

            </StackPanel>

        </Border>

        <!-- CHAT AREA -->

        <Border Grid.Row="1"
                Margin="10"
                CornerRadius="15"
                Background="#17212B">

            <TextBox
                Name="ChatBox"
                Background="#17212B"
                Foreground="White"
                FontSize="16"
                BorderThickness="0"
                TextWrapping="Wrap"
                AcceptsReturn="True"
                IsReadOnly="True"
                VerticalScrollBarVisibility="Auto"
                Padding="15"/>

        </Border>

        <!-- INPUT -->

        <Border Grid.Row="2"
                Margin="10"
                CornerRadius="15"
                Background="#1B263B">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="170"/>
                </Grid.ColumnDefinitions>

                <TextBox
                    Name="UserInputBox"
                    Margin="15"
                    FontSize="18"
                    VerticalContentAlignment="Center"
                    KeyDown="UserInputBox_KeyDown"/>

                <Button
                    Grid.Column="1"
                    Name="SendButton"
                    Content="SEND"
                    FontSize="18"
                    FontWeight="Bold"
                    Background="Cyan"
                    Foreground="Black"
                    Margin="10"
                    Click="SendButton_Click"/>

            </Grid>

        </Border>

    </Grid>
</Window>